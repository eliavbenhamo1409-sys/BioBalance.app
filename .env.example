# Copy this file to .env and fill in your keys
#
# LLM: all chat, vision, onboarding, insights, and food pipeline AI use Gemini via
# Supabase Edge Function `gemini-proxy` (set secret GEMINI_API_KEY in Supabase Dashboard).
# The app does not use OpenAI.

# Supabase (client). Prefer env over hardcoded fallbacks in supabaseClient.js.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Must match Supabase Edge Function secret DAILY_MESSAGE_LIMIT (server enforces real cap).
# Used for the "X messages left today" banner and for client-side increment_api_usage on direct calls.
EXPO_PUBLIC_DAILY_MESSAGE_LIMIT=60

# If Edge/logs show 403 PERMISSION_DENIED from Google, the Supabase secret key is bad or the
# Google project was blocked — set a fresh key here for local fallback (then restart `npx expo start`):
# GEMINI_API_KEY=
#
# Single key name for local/dev: app.config.js copies this into extra.geminiApiKeyForDirect
# (same as EXPO_PUBLIC_GEMINI_API_KEY for Metro). Still exposed in the client bundle in direct mode.

# Optional explicit client var (overrides GEMINI_API_KEY for bundler if both set).
# EXPO_PUBLIC_GEMINI_API_KEY=

# Optional: if Edge returns 403 / project denied, set true so the app calls Google from the device.
# EXPO_PUBLIC_GEMINI_USE_DIRECT=

# Food verifier (final Gemini sanity-check after nutrition resolution).
# Default ON. Set to 0 to disable — chat falls back to resolver-supplied numbers.
# EXPO_PUBLIC_FOOD_VERIFIER_ENABLED=1
